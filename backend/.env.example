PORT=4000
NODE_ENV=development
# Comma-separated allowed browser origins (Vite default 5173, CRA 3000)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOW_DEV_AUTH=true
USE_MEMORY_DB=true

# Firebase Admin credentials (optional if USE_MEMORY_DB=true)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
